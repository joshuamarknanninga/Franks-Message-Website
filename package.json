{
  "name": "franks-message-website",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for Frank's Message Website",
  "scripts": {
    "setup": "npm --prefix server install && npm --prefix client install",
    "predev": "npm run setup",
    "dev": "sh -c 'npm --prefix server run dev & npm --prefix client run dev & wait'",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "start": "npm --prefix server run start",
    "seed": "npm --prefix server run seed",
    "client:build": "npm --prefix client run build"
  }
}
